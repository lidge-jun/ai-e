{
  "name": "ai-e",
  "version": "0.1.0",
  "description": "Modular exec wrapper for interactive and headless AI CLIs",
  "keywords": [
    "ai",
    "exec",
    "multi-provider",
    "claude",
    "codex",
    "gemini",
    "grok",
    "claude-code",
    "cli",
    "pty",
    "rust",
    "ai-agents",
    "automation",
    "cli-jaw"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lidge-jun/ai-e.git"
  },
  "homepage": "https://github.com/lidge-jun/ai-e#readme",
  "bugs": {
    "url": "https://github.com/lidge-jun/ai-e/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ai-e": "bin/ai-e"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "cargo build --release --locked",
    "test": "cargo test --locked && npm run test:postinstall",
    "test:postinstall": "node --test tests/star-prompt.test.cjs",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt --check",
    "check": "cargo check --locked",
    "verify": "npm run fmt:check && npm run test && npm run build",
    "pack:dry": "npm pack --dry-run",
    "publish:dry-run": "node scripts/publish-dry-run.mjs",
    "prepublishOnly": "npm run verify && npm run publish:dry-run",
    "release:check": "bash scripts/release-npm.sh --dry-run",
    "release:dry-run": "bash scripts/release-npm.sh --dry-run",
    "release:npm": "bash scripts/release-npm.sh --publish",
    "release:publish-current": "bash scripts/release-npm.sh --publish",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:preview": "bash scripts/release-preview.sh",
    "smoke": "bash scripts/smoke.sh",
    "install:local": "cargo install --path . --locked"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "Cargo.toml",
    "Cargo.lock",
    "README.md",
    "LICENSE",
    "structure/"
  ]
}
